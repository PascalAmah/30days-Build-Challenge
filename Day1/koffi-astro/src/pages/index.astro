---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import WhySection from '../components/WhySection.astro';
---
<Layout>
  <main>
    <Hero />
    <WhySection />

    <footer id="blends" class="border-t border-[var(--koffi-brown)]/10 bg-[var(--koffi-cream)] px-6 py-10 text-center text-sm text-[var(--koffi-muted)] sm:px-10">
      <p>&copy; {new Date().getFullYear()} Koffi. Made for slow mornings.</p>
    </footer>
  </main>
</Layout>
